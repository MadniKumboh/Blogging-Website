{
	"name": "Blogging Website",
	"version": "1.0.0",
	"description": "Trying to MAke Premium Blogging Website",
	"scripts": {
		"lint:html": "htmlhint 'src/**/*.html'",
		"lint:css": "stylelint 'styles/**/*.css'",
		"lint": "npm run lint:html && npm run lint:css",
		"lint:fix": "stylelint 'styles/**/*.css' --fix",
		"start": "parcel src/index.html",
		"build": "parcel build src/index.html --dist-dir dist --public-url ./"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/MadniKumboh/Blogging-Website.git"
	},
	"keywords": [
		"blog",
		"website",
		"html",
		"css"
	],
